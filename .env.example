# touch-grass-mcp — API keys for source providers.
# Copy this file to .env and fill in the keys you have.
# The MCP server runs without any of these, but features that need them will be skipped.

# Ticketmaster Discovery API — concerts, sports, theater
# Get one: https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=

# Eventbrite — community + paid events
# Get one: https://www.eventbrite.com/platform/api (private token)
EVENTBRITE_API_KEY=

# Yelp Fusion — restaurants, bars, breweries
# Get one: https://docs.developer.yelp.com/
YELP_API_KEY=

# Meetup — group events (public scrape works without a key, but slower)
# Optional: https://www.meetup.com/api/
MEETUP_API_KEY=

# NYC Open Data (Socrata) — NYC government datasets, higher rate limit with token
# Optional: https://data.cityofnewyork.us/profile/edit/developer_settings
NYC_OPENDATA_TOKEN=

# Browser-fingerprint impersonation for fragile NYC museum scrapers
# Set to "true" only if you're OK with curl-cffi presenting as Chrome to bypass anti-bot.
# Some sites' ToS forbid this. Off by default.
TOUCH_GRASS_NYC_IMPERSONATE=false

# Pulse system — Reddit + Google Trends + RSS for cultural trend tracking
# Optional: leave empty to disable pulse re-ranking
TOUCH_GRASS_PULSE_ENABLED=true
